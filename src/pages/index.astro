---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Wallet | Control de Gastos">
  <header>
    <div class="user-info" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
      <div style="display: flex; align-items: center;">
        <div class="avatar">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" style="width: 24px; height: 24px; margin: 8px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <div>
          <div class="greeting">Hola,</div>
          <div class="name" id="userNameDisplay">Cargando...</div>
        </div>
      </div>
      <div>
        <select id="monthFilter" style="background: var(--card-bg); color: var(--text-primary); border: 1px solid var(--card-border); padding: 4px 8px; border-radius: 8px; font-family: 'Outfit', sans-serif; font-size: 0.85rem; outline: none; cursor: pointer;">
          <option value="current">Este mes</option>
          <option value="last">Mes pasado</option>
          <option value="all">Todos</option>
        </select>
      </div>
    </div>
  </header>

  <main class="main-content">
    <div class="balance-card">
      <div class="balance-label">Gasto del mes</div>
      <div class="balance-amount" id="globalBalanceAmount">$0</div>
      
      <div class="balance-stats">
        <div class="stat">
          <div class="stat-label">
            <span>📉</span> Gastos
          </div>
          <div class="stat-amount" id="balanceAmount">$0</div>
        </div>
        <div class="stat">
          <div class="stat-label">
            <span>📈</span> Ingresos
          </div>
          <div class="stat-amount" id="incomeAmount">$0</div>
        </div>
      </div>
    </div>

    <!-- SECCIÓN CUENTAS -->
    <div style="margin-top: 24px; display: flex; justify-content: space-between; align-items: center;">
      <h3 style="font-size: 1rem; font-weight: 600;">Cuentas</h3>
      <div style="display: flex; gap: 12px; align-items: center;">
        <button id="openAccountModalBtn" style="background: var(--card-bg); color: var(--text-primary); border: 1px solid var(--card-border); padding: 4px 12px; border-radius: 8px; font-size: 0.8rem; cursor: pointer;">+ Nueva</button>
      </div>
    </div>
    <div id="accountsCarousel" style="display: flex; gap: 12px; overflow-x: auto; padding: 8px 0; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; margin-bottom: 8px;">
      <!-- Llenado dinámico -->
    </div>

    <div class="quick-actions">
      <button class="action-item" id="btnAddTransaction">
        <div class="action-icon" style="background: var(--accent-gradient); border: none;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px; color: white;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <div class="action-label">Añadir</div>
      </button>
      <button class="action-item" id="btnReceive">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <div class="action-label">Recibir</div>
      </button>
      <button class="action-item" onclick="window.location.href='/analisis'">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <div class="action-label">Análisis</div>
      </button>
      <button class="action-item" onclick="window.location.href='/perfil'">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <div class="action-label">Perfil</div>
      </button>
    </div>

    <!-- SECCIÓN METAS -->
    <div class="section-header" style="margin-top: 24px; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="section-title">Mis Metas</h2>
      <button id="openGoalModalBtn" style="background: var(--accent); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; font-size: 1.2rem; cursor: pointer;">+</button>
    </div>
    <div id="goalsList" style="margin-bottom: 24px;">
      <!-- Se llena por JS -->
    </div>

    <!-- SECCIÓN TRANSACCIONES -->
    <div class="section-header">
      <h2 class="section-title">Actividad Reciente</h2>
    </div>

    <div class="transaction-list" id="transaction-list" style="margin-bottom: 80px;">
      <div class="empty-state">Cargando transacciones...</div>
    </div>
  </main>

  <BottomNav slot="bottom-nav" currentPath="/" />

  <!-- Modal para Nueva Transacción -->
  <div class="modal-overlay" id="transactionModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Nueva Transacción</h3>
        <button class="close-btn" id="closeModalBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <form id="transactionForm">
        <div class="type-selector">
          <button type="button" class="type-btn active expense" data-type="expense">Gasto</button>
          <button type="button" class="type-btn income" data-type="income">Ingreso</button>
        </div>

        <div class="form-group">
          <label class="form-label">Título</label>
          <input type="text" class="form-input" id="txTitle" placeholder="Ej. Supermercado, Salario..." required>
        </div>

        <div class="form-group">
          <label class="form-label">Categoría</label>
          <select class="form-input" id="txCategory" required style="appearance: none; padding-right: 32px; background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2394a3b8%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 12px top 50%; background-size: 16px auto;">
            <option value="Alimentación" style="color: black;">Alimentación</option>
            <option value="Transporte" style="color: black;">Transporte</option>
            <option value="Ocio" style="color: black;">Ocio</option>
            <option value="Servicios" style="color: black;">Servicios</option>
            <option value="Salud" style="color: black;">Salud</option>
            <option value="Otros" style="color: black;">Otros</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Cuenta</label>
          <select class="form-input" id="txAccount" required style="appearance: none; padding-right: 32px; background-color: var(--input-bg); color: var(--text-primary);">
            <option value="principal" style="color: black;">Cuenta Principal</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Monto</label>
          <input type="text" inputmode="numeric" class="form-input" id="txAmount" placeholder="Ej: 15.000" required>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">Guardar Transacción</button>
      </form>
    </div>
  </div>

  <!-- Modal para Nueva Meta -->
  <div class="modal-overlay" id="goalModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Nueva Meta de Ahorro</h3>
        <button class="close-btn" id="closeGoalModalBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="goalForm">
        <div class="form-group">
          <label class="form-label">Título de la Meta (Ej. Viaje)</label>
          <input type="text" class="form-input" id="goalTitle" required>
        </div>
        <div class="form-group">
          <label class="form-label">Monto Objetivo</label>
          <input type="text" inputmode="numeric" class="form-input" id="goalAmount" placeholder="Ej: 50.000" required>
        </div>
        <button type="submit" class="submit-btn" id="saveGoalBtn">Crear Meta</button>
      </form>
    </div>
  </div>

  <!-- Modal para Aportar a Meta -->
  <div class="modal-overlay" id="depositModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Aportar a Meta</h3>
        <button class="close-btn" id="closeDepositModalBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="depositForm">
        <div class="form-group">
          <label class="form-label" id="depositSubtitle">Aportando a...</label>
          <input type="text" inputmode="numeric" class="form-input" id="depositAmount" placeholder="Ej: 5.000" required>
        </div>
        <button type="submit" class="submit-btn" id="saveDepositBtn">Sumar a la Meta</button>
      </form>
    </div>
  </div>

  <!-- Modal para Nueva Cuenta -->
  <div class="modal-overlay" id="accountModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Nueva Cuenta</h3>
        <button class="close-btn" id="closeAccountModalBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="accountForm">
        <div class="form-group">
          <label class="form-label">Nombre de la cuenta</label>
          <input type="text" class="form-input" id="accName" placeholder="Ej: Cuenta Ahorro" required>
        </div>
        <div class="form-group">
          <label class="form-label">Saldo Inicial</label>
          <input type="text" inputmode="numeric" class="form-input" id="accBalance" placeholder="Ej: 100.000" required>
        </div>
        <button type="submit" class="submit-btn" id="saveAccountBtn">Crear Cuenta</button>
      </form>
    </div>
  </div>
  <!-- Delete Account Modal -->
  <div class="modal-overlay" id="deleteAccountModal">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-title">Eliminar Cuenta</div>
        <button class="close-btn" id="closeDeleteAccBtn">×</button>
      </div>
      <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 0.9rem;">
        ¿Qué deseas hacer con las transacciones asociadas a esta cuenta?
      </p>
      <div class="form-group">
        <label class="form-label">Acción</label>
        <select id="deleteAccountAction" class="form-input" style="color: black;">
          <option value="none">Dejarlas sin cuenta (solo historial)</option>
        </select>
      </div>
      <button class="submit-btn" id="confirmDeleteAccBtn" style="background: var(--negative);">Eliminar Cuenta</button>
    </div>
  </div>

</Layout>

<script>
  import { auth, accountsCol, addAccount, deleteAccountDb, transactionsCol, goalsCol, subscriptionsCol, addTransaction, addGoal, deleteTransactionDb, updateTransactionDb, onSnapshot, query, where, updateDoc, doc, deleteDoc, db } from '../lib/firebase.js';

  let currentType = 'expense';
  let allTransactions = [];
  let displayedTransactions = [];
  let currentUser = null;
  let editingTxId = null;
  let unsubscribeTx = null;
  let unsubscribeGoals = null;
  let unsubscribeSubs = null;
  let unsubscribeAccounts = null;
  let allGoals = [];
  let allSubscriptions = [];
  let allAccounts = [];
  let currentGoalToDeposit = null;
  let accountsVisible = true;

  const listEl = document.getElementById('transaction-list');
  const userNameDisplay = document.getElementById('userNameDisplay');
  const monthFilter = document.getElementById('monthFilter');
  
  // Tx Modal
  const modal = document.getElementById('transactionModal');
  const btnAdd = document.getElementById('btnAddTransaction');
  const btnReceive = document.getElementById('btnReceive');
  const btnClose = document.getElementById('closeModalBtn');
  const form = document.getElementById('transactionForm');
  const typeBtns = document.querySelectorAll('.type-btn');
  const btnIncomeType = document.querySelector('.type-btn.income');
  const submitBtn = document.getElementById('submitBtn');

  // Goals
  const goalsList = document.getElementById('goalsList');
  const openGoalModalBtn = document.getElementById('openGoalModalBtn');
  const goalModal = document.getElementById('goalModal');
  const closeGoalModalBtn = document.getElementById('closeGoalModalBtn');
  const goalForm = document.getElementById('goalForm');
  const saveGoalBtn = document.getElementById('saveGoalBtn');

  // Deposit
  const depositModal = document.getElementById('depositModal');
  const closeDepositModalBtn = document.getElementById('closeDepositModalBtn');
  const depositForm = document.getElementById('depositForm');
  const saveDepositBtn = document.getElementById('saveDepositBtn');
  const depositSubtitle = document.getElementById('depositSubtitle');

  // Accounts
  const accountModal = document.getElementById('accountModal');
  const closeAccountModalBtn = document.getElementById('closeAccountModalBtn');
  const openAccountModalBtn = document.getElementById('openAccountModalBtn');
  const accountForm = document.getElementById('accountForm');
  const saveAccountBtn = document.getElementById('saveAccountBtn');
  const accountsCarousel = document.getElementById('accountsCarousel');
  const txAccountSelect = document.getElementById('txAccount');

  const formatCurrency = (amount) => Math.round(Math.abs(amount)).toLocaleString('es-CL') + ' CLP';

  const getFormattedDate = () => {
    const now = new Date();
    return now.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit' });
  };

  const filterTransactions = () => {
    const filter = monthFilter.value;
    if (filter === 'all') {
      displayedTransactions = [...allTransactions];
    } else {
      const now = new Date();
      const currentMonth = now.getMonth();
      const currentYear = now.getFullYear();

      displayedTransactions = allTransactions.filter(tx => {
        if (!tx.createdAt) return true; 
        const txDate = new Date(tx.createdAt);
        if (filter === 'current') return txDate.getMonth() === currentMonth && txDate.getFullYear() === currentYear;
        if (filter === 'last') {
          let lastMonth = currentMonth - 1;
          let lastYear = currentYear;
          if (lastMonth < 0) { lastMonth = 11; lastYear--; }
          return txDate.getMonth() === lastMonth && txDate.getFullYear() === lastYear;
        }
        return true;
      });
    }
    updateUI();
  };

  monthFilter.addEventListener('change', filterTransactions);

  const updateUI = () => {
    let income = displayedTransactions.filter(t => t.amount > 0).reduce((acc, t) => acc + t.amount, 0);
    let expense = displayedTransactions.filter(t => t.amount < 0).reduce((acc, t) => acc + t.amount, 0);
    
    // Add subscriptions to expenses
    const subsTotal = allSubscriptions.reduce((acc, sub) => acc + parseFloat(sub.amount), 0);
    expense -= subsTotal;

    // Calcular saldos por cuenta
    let accountsBalance = {};
    let globalBalance = 0;
    accountsCarousel.innerHTML = '';

    if (allAccounts.length > 0) {
      allAccounts.forEach(acc => {
        accountsBalance[acc.id] = { name: acc.name, balance: acc.initialBalance || 0 };
      });
      
      displayedTransactions.forEach(t => {
        let accId = t.accountId;
        if (!accId || accId === 'principal' || accId === 'none' || !accountsBalance[accId]) {
          return; // No afecta ninguna cuenta
        }
        accountsBalance[accId].balance += t.amount;
      });

      const defaultAccId = allAccounts[0].id;
      if (accountsBalance[defaultAccId]) {
        accountsBalance[defaultAccId].balance -= subsTotal;
      }

      const accKeys = Object.keys(accountsBalance);
      accKeys.forEach(key => {
        const acc = accountsBalance[key];
        const accId = key;
        globalBalance += acc.balance;

        const div = document.createElement('div');
        div.style.minWidth = '140px';
        div.style.background = 'var(--card-bg)';
        div.style.border = '1px solid var(--card-border)';
        div.style.borderRadius = '16px';
        div.style.padding = '12px';
        div.style.position = 'relative';
        div.style.scrollSnapAlign = 'start';
        div.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;">
            <div style="font-size: 0.8rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 90px;">${acc.name}</div>
            <button onclick="window.deleteAccount('${accId}')" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1rem; padding: 0; line-height: 1;">×</button>
          </div>
          <div style="font-weight: 600; font-size: 1.1rem;" class="account-balance-text">${formatCurrency(acc.balance)}</div>
        `;
        accountsCarousel.appendChild(div);
      });
    } else {
      globalBalance = income + expense;
      const div = document.createElement('div');
      div.style.color = 'var(--text-secondary)';
      div.style.fontSize = '0.85rem';
      div.textContent = 'No tienes cuentas creadas.';
      accountsCarousel.appendChild(div);
    }

    // Append 'Add Account' card
    const addAccDiv = document.createElement('div');
    addAccDiv.style.minWidth = '140px';
    addAccDiv.style.background = 'rgba(255, 255, 255, 0.05)';
    addAccDiv.style.border = '1px dashed var(--text-secondary)';
    addAccDiv.style.borderRadius = '16px';
    addAccDiv.style.padding = '12px';
    addAccDiv.style.display = 'flex';
    addAccDiv.style.flexDirection = 'column';
    addAccDiv.style.alignItems = 'center';
    addAccDiv.style.justifyContent = 'center';
    addAccDiv.style.cursor = 'pointer';
    addAccDiv.style.scrollSnapAlign = 'start';
    addAccDiv.onclick = () => { document.getElementById('accountModal').classList.add('active'); };
    addAccDiv.innerHTML = `
      <div style="font-size: 1.5rem; color: var(--text-secondary); margin-bottom: 4px;">+</div>
      <div style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 500;">Agregar Cuenta</div>
    `;
    accountsCarousel.appendChild(addAccDiv);

    document.getElementById('balanceAmount').textContent = formatCurrency(Math.abs(expense));
    document.getElementById('globalBalanceAmount').textContent = formatCurrency(globalBalance);
    document.getElementById('incomeAmount').textContent = formatCurrency(income);

    // Actualizar select de cuentas en modal de transacciones
    const currentTxAcc = txAccountSelect.value;
    txAccountSelect.innerHTML = `<option value="none" style="color: black;">Ninguna (Solo registrar)</option>`;
    
    allAccounts.forEach(acc => {
      txAccountSelect.innerHTML += `<option value="${acc.id}" style="color: black;">${acc.name}</option>`;
    });

    if (currentTxAcc && (currentTxAcc === 'none' || allAccounts.some(a => a.id === currentTxAcc))) {
      txAccountSelect.value = currentTxAcc;
    } else if (allAccounts.length > 0) {
      txAccountSelect.value = allAccounts[0].id;
    } else {
      txAccountSelect.value = 'none';
    }

    listEl.innerHTML = '';
    
    if (displayedTransactions.length === 0 && subsTotal === 0) {
      listEl.innerHTML = '<div class="empty-state">No hay transacciones en este periodo.</div>';
      return;
    }

    // Dummy transaction for subscriptions
    if (subsTotal > 0) {
      const div = document.createElement('div');
      div.className = 'transaction-item';
      div.innerHTML = `
        <div class="tx-left">
          <div class="tx-icon" style="background-color: rgba(248, 113, 113, 0.2);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px; color: #f87171;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <div class="tx-details">
            <div class="tx-title">Suscripciones Fijas</div>
            <div class="tx-date">Costo recurrente del periodo</div>
          </div>
        </div>
        <div class="tx-amount" style="color: var(--negative);">
          -${formatCurrency(subsTotal)}
        </div>
      `;
      listEl.appendChild(div);
    }

    displayedTransactions.forEach(tx => {
      const isPositive = tx.amount > 0;
      let colorCode = isPositive ? '#34d399' : '#f87171';
      let bgStyle = isPositive ? 'background-color: rgba(52, 211, 153, 0.2)' : 'background-color: rgba(248, 113, 113, 0.2)';
      let iconSvg = isPositive 
        ? '<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l6.75-6.75M12 19.5l-6.75-6.75" />' 
        : '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />';

      const div = document.createElement('div');
      div.className = 'transaction-item';
      div.onclick = () => window.editTransaction(tx.id, tx.title, tx.category, tx.amount);
      div.innerHTML = `
        <div class="tx-left">
          <div class="tx-icon" style="${bgStyle}">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px; color: ${colorCode}">
              ${iconSvg}
            </svg>
          </div>
          <div class="tx-details">
            <div class="tx-title">${tx.title}</div>
            <div class="tx-date">${tx.date} • ${tx.category}</div>
          </div>
        </div>
        <div class="tx-amount ${isPositive ? 'positive' : ''}" style="${isPositive ? 'color: var(--positive);' : ''}">
          ${isPositive ? '+' : '-'}${formatCurrency(tx.amount)}
        </div>
        <button class="delete-btn" onclick="event.stopPropagation(); window.deleteTransaction('${tx.id}')" title="Eliminar">×</button>
      `;
      listEl.appendChild(div);
    });
  };

  const renderGoals = () => {
    goalsList.innerHTML = '';
    if (allGoals.length === 0) {
      goalsList.innerHTML = '<div class="empty-state" style="margin-bottom: 0;">Aún no has creado metas. ¡Ahorra para ese viaje!</div>';
      return;
    }

    allGoals.forEach(goal => {
      const percentage = Math.min((goal.current / goal.target) * 100, 100).toFixed(1);
      const div = document.createElement('div');
      div.style.background = 'var(--card-bg)';
      div.style.border = '1px solid var(--card-border)';
      div.style.borderRadius = '16px';
      div.style.padding = '16px';
      div.style.marginBottom = '12px';

      div.innerHTML = `
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 12px;">
          <div>
            <div style="font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">Meta</div>
            <div style="font-weight: 600; font-size: 1.1rem; color: var(--text-primary);">${goal.title}</div>
          </div>
          <div style="text-align: right;">
            <div style="font-size: 1.1rem; font-weight: 600; color: var(--positive);">${formatCurrency(goal.current)}</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">de ${formatCurrency(goal.target)}</div>
          </div>
        </div>
        <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-bottom: 12px;">
          <div style="width: ${percentage}%; height: 100%; background: var(--positive); transition: width 0.5s ease;"></div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 0.8rem; color: var(--text-secondary);">${percentage}% completado</span>
          <div style="display: flex; gap: 8px;">
            <button onclick="window.openDepositModal('${goal.id}', '${goal.title}', ${goal.current})" style="background: rgba(52, 211, 153, 0.1); color: var(--positive); border: 1px solid rgba(52, 211, 153, 0.2); padding: 6px 12px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">Aportar</button>
            <button onclick="window.deleteGoal('${goal.id}')" style="background: none; color: var(--text-secondary); border: 1px solid var(--card-border); padding: 6px 8px; border-radius: 8px; font-size: 0.85rem; cursor: pointer;">×</button>
          </div>
        </div>
      `;
      goalsList.appendChild(div);
    });
  };

  const loadUserData = (user) => {
    currentUser = user;
    userNameDisplay.textContent = user.displayName || user.email.split('@')[0];

    // Listen Transactions
    if (unsubscribeTx) unsubscribeTx();
    const qTx = query(transactionsCol, where("userId", "==", user.uid));
    unsubscribeTx = onSnapshot(qTx, (snapshot) => {
      allTransactions = [];
      snapshot.forEach((doc) => {
        allTransactions.push({ id: doc.id, ...doc.data() });
      });
      allTransactions.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
      filterTransactions();
    });

    // Listen Goals
    if (unsubscribeGoals) unsubscribeGoals();
    const qGoals = query(goalsCol, where("userId", "==", user.uid));
    unsubscribeGoals = onSnapshot(qGoals, (snapshot) => {
      allGoals = [];
      snapshot.forEach(doc => {
        allGoals.push({ id: doc.id, ...doc.data() });
      });
      renderGoals();
    });

    // Listen Subscriptions
    if (unsubscribeSubs) unsubscribeSubs();
    const qSubs = query(subscriptionsCol, where("userId", "==", user.uid));
    unsubscribeSubs = onSnapshot(qSubs, (snapshot) => {
      allSubscriptions = [];
      snapshot.forEach(doc => {
        allSubscriptions.push({ id: doc.id, ...doc.data() });
      });
      filterTransactions(); // re-calculate totals
    });

    // Listen Accounts
    if (unsubscribeAccounts) unsubscribeAccounts();
    const qAcc = query(accountsCol, where("userId", "==", user.uid));
    unsubscribeAccounts = onSnapshot(qAcc, (snapshot) => {
      allAccounts = [];
      snapshot.forEach(doc => {
        allAccounts.push({ id: doc.id, ...doc.data() });
      });
      filterTransactions(); // re-calculate totals with new accounts
    });
  };

  auth.onAuthStateChanged((user) => {
    if (user) {
      loadUserData(user);
    }
  });

  // Export functions to window so inline onclick handlers work
  window.deleteTransaction = async (id) => {
    if(confirm("¿Eliminar transacción?")) await deleteTransactionDb(id);
  };
  let accountToDelete = null;
  const deleteAccountModal = document.getElementById('deleteAccountModal');
  const deleteAccountAction = document.getElementById('deleteAccountAction');

  window.deleteAccount = (id) => {
    accountToDelete = id;
    deleteAccountAction.innerHTML = '<option value="none" style="color: black;">Dejarlas sin cuenta (solo historial)</option>';
    allAccounts.forEach(acc => {
      if (acc.id !== id) {
        deleteAccountAction.innerHTML += `<option value="${acc.id}" style="color: black;">Mover a: ${acc.name}</option>`;
      }
    });
    deleteAccountModal.classList.add('active');
  };

  document.getElementById('closeDeleteAccBtn').addEventListener('click', () => {
    deleteAccountModal.classList.remove('active');
    accountToDelete = null;
  });

  document.getElementById('confirmDeleteAccBtn').addEventListener('click', async () => {
    if (!accountToDelete) return;
    document.getElementById('confirmDeleteAccBtn').disabled = true;
    document.getElementById('confirmDeleteAccBtn').textContent = 'Procesando...';
    
    const targetAccId = deleteAccountAction.value;
    const txsToUpdate = allTransactions.filter(t => t.accountId === accountToDelete);
    
    for(let t of txsToUpdate) {
      await updateTransactionDb(t.id, { accountId: targetAccId });
    }
    
    await deleteAccountDb(accountToDelete);
    
    deleteAccountModal.classList.remove('active');
    accountToDelete = null;
    document.getElementById('confirmDeleteAccBtn').disabled = false;
    document.getElementById('confirmDeleteAccBtn').textContent = 'Eliminar Cuenta';
  });
  window.editTransaction = (id, title, category, amount) => {
    editingTxId = id;
    document.querySelector('.modal-title').textContent = 'Editar Transacción';
    submitBtn.textContent = 'Actualizar Transacción';
    
    document.getElementById('txTitle').value = title;
    document.getElementById('txCategory').value = category;
    document.getElementById('txAmount').value = Math.abs(amount);
    
    const tx = allTransactions.find(t => t.id === id);
    if (tx && tx.accountId === 'none') {
      document.getElementById('txAccount').value = 'none';
    } else if (tx && tx.accountId && allAccounts.some(a => a.id === tx.accountId)) {
      document.getElementById('txAccount').value = tx.accountId;
    } else if (allAccounts.length > 0) {
      document.getElementById('txAccount').value = allAccounts[0].id;
    } else {
      document.getElementById('txAccount').value = 'none';
    }
    
    const isIncome = amount > 0;
    currentType = isIncome ? 'income' : 'expense';
    
    typeBtns.forEach(b => b.classList.remove('active'));
    if (isIncome) {
      document.querySelector('.type-btn.income').classList.add('active');
      document.getElementById('txCategory').innerHTML = `<option value="Salario" style="color: black;">Salario</option><option value="Regalo" style="color: black;">Regalo</option><option value="Inversión" style="color: black;">Inversión</option><option value="Otros" style="color: black;">Otros</option>`;
      document.getElementById('txCategory').value = category;
    } else {
      document.querySelector('.type-btn.expense').classList.add('active');
      document.getElementById('txCategory').innerHTML = `<option value="Alimentación" style="color: black;">Alimentación</option><option value="Transporte" style="color: black;">Transporte</option><option value="Ocio" style="color: black;">Ocio</option><option value="Servicios" style="color: black;">Servicios</option><option value="Salud" style="color: black;">Salud</option><option value="Otros" style="color: black;">Otros</option>`;
      document.getElementById('txCategory').value = category;
    }
    
    modal.classList.add('active');
  };
  window.deleteGoal = async (id) => {
    if(confirm("¿Seguro que quieres borrar esta meta?")) {
      await deleteDoc(doc(db, "goals", id));
    }
  };
  window.openDepositModal = (id, title, current) => {
    currentGoalToDeposit = { id, current };
    depositSubtitle.textContent = `Aportando a: ${title}`;
    depositModal.classList.add('active');
    setTimeout(() => document.getElementById('depositAmount').focus(), 100);
  };

  // Transaction form handlers
  btnAdd.addEventListener('click', () => { 
    editingTxId = null; 
    document.querySelector('.modal-title').textContent = 'Nueva Transacción'; 
    submitBtn.textContent = 'Guardar Transacción'; 
    modal.classList.add('active'); 
    setTimeout(() => document.getElementById('txTitle').focus(), 100); 
  });
  btnReceive.addEventListener('click', () => { 
    editingTxId = null; 
    document.querySelector('.modal-title').textContent = 'Nueva Transacción'; 
    submitBtn.textContent = 'Guardar Transacción'; 
    modal.classList.add('active'); 
    btnIncomeType.click(); 
    setTimeout(() => document.getElementById('txTitle').focus(), 100); 
  });
  btnClose.addEventListener('click', () => { modal.classList.remove('active'); form.reset(); editingTxId = null; });
  typeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentType = btn.dataset.type;
      const catSelect = document.getElementById('txCategory');
      if (currentType === 'income') {
        catSelect.innerHTML = `<option value="Salario" style="color: black;">Salario</option><option value="Regalo" style="color: black;">Regalo</option><option value="Inversión" style="color: black;">Inversión</option><option value="Otros" style="color: black;">Otros</option>`;
      } else {
        catSelect.innerHTML = `<option value="Alimentación" style="color: black;">Alimentación</option><option value="Transporte" style="color: black;">Transporte</option><option value="Ocio" style="color: black;">Ocio</option><option value="Servicios" style="color: black;">Servicios</option><option value="Salud" style="color: black;">Salud</option><option value="Otros" style="color: black;">Otros</option>`;
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentUser) return;
    submitBtn.disabled = true; submitBtn.textContent = 'Guardando...';
    
    const title = document.getElementById('txTitle').value;
    const category = document.getElementById('txCategory').value;
    const accountId = document.getElementById('txAccount').value;
    const rawAmount = document.getElementById('txAmount').value;
    const amountVal = parseFloat(rawAmount.replace(/\./g, '').replace(/,/g, '.'));
    
    if (title && !isNaN(amountVal)) {
      const finalAmount = currentType === 'expense' ? -amountVal : amountVal;
      if (editingTxId) {
        await updateTransactionDb(editingTxId, { title, category, accountId, amount: finalAmount });
      } else {
        await addTransaction({ title, category, accountId, amount: finalAmount, date: getFormattedDate(), userId: currentUser.uid });
      }
    }
    modal.classList.remove('active'); form.reset(); submitBtn.disabled = false; submitBtn.textContent = 'Guardar Transacción';
    editingTxId = null;
  });

  // Goals handlers
  openGoalModalBtn.addEventListener('click', () => goalModal.classList.add('active'));
  closeGoalModalBtn.addEventListener('click', () => { goalModal.classList.remove('active'); goalForm.reset(); });
  
  goalForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentUser) return;
    saveGoalBtn.disabled = true; saveGoalBtn.textContent = 'Creando...';
    
    const title = document.getElementById('goalTitle').value;
    const rawTarget = document.getElementById('goalAmount').value;
    const target = parseFloat(rawTarget.replace(/\./g, '').replace(/,/g, '.'));
    if(title && !isNaN(target)) {
      await addGoal({ userId: currentUser.uid, title, target, current: 0 });
    }
    goalModal.classList.remove('active'); goalForm.reset(); saveGoalBtn.disabled = false; saveGoalBtn.textContent = 'Crear Meta';
  });

  // Deposit handlers
  closeDepositModalBtn.addEventListener('click', () => { depositModal.classList.remove('active'); depositForm.reset(); });
  depositForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentGoalToDeposit) return;
    saveDepositBtn.disabled = true; saveDepositBtn.textContent = 'Sumando...';

    const rawAmt = document.getElementById('depositAmount').value;
    const amt = parseFloat(rawAmt.replace(/\./g, '').replace(/,/g, '.'));
    if(!isNaN(amt)) {
      const newCurrent = currentGoalToDeposit.current + amt;
      await updateDoc(doc(db, "goals", currentGoalToDeposit.id), { current: newCurrent });
    }
    depositModal.classList.remove('active'); depositForm.reset(); saveDepositBtn.disabled = false; saveDepositBtn.textContent = 'Sumar a la Meta';
  });

  // Accounts Handlers
  openAccountModalBtn.addEventListener('click', () => accountModal.classList.add('active'));
  closeAccountModalBtn.addEventListener('click', () => { accountModal.classList.remove('active'); accountForm.reset(); });
  accountForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentUser) return;

    const name = document.getElementById('accName').value;
    const initialBalanceStr = document.getElementById('accBalance').value.replace(/\./g, '');
    const initialBalance = parseFloat(initialBalanceStr);

    if (name && !isNaN(initialBalance)) {
      const submitBtn = accountForm.querySelector('.submit-btn');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando...';

      try {
        const newAccId = await addAccount({
          userId: currentUser.uid,
          name,
          initialBalance
        });
        
        const orphanedTxs = allTransactions.filter(t => !t.accountId || t.accountId === 'principal' || t.accountId === 'none');
        if (orphanedTxs.length > 0) {
          if(confirm(`Tienes ${orphanedTxs.length} transacciones sin cuenta asignada. ¿Quieres asociarlas a esta nueva cuenta para que se descuenten/sumen de aquí?`)) {
            for(let t of orphanedTxs) {
              await updateTransactionDb(t.id, { accountId: newAccId });
            }
          }
        }

        document.getElementById('accountModal').classList.remove('active');
        accountForm.reset();
      } catch (err) {
        alert("Error al guardar la cuenta: " + err.message);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Crear Cuenta';
      }
    }
  });

</script>
