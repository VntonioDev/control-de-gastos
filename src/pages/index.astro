---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Wallet | Control de Gastos">
  <header>
    <div class="user-info">
      <div class="avatar">
        <img src="https://i.pravatar.cc/150?img=11" alt="User Avatar" />
      </div>
      <div>
        <div class="greeting">Buenos días,</div>
        <div class="name">Jose</div>
      </div>
    </div>
  </header>

  <main class="main-content">
    <div class="balance-card">
      <div class="balance-label">Balance Total</div>
      <div class="balance-amount" id="total-balance">$0.00</div>
      <div class="balance-stats">
        <div class="stat">
          <div class="stat-label">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l-6.75 6.75M12 4.5l6.75 6.75" />
            </svg>
            Ingresos
          </div>
          <div class="stat-amount" id="total-income">$0.00</div>
        </div>
        <div class="stat">
          <div class="stat-label">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l6.75-6.75M12 19.5l-6.75-6.75" />
            </svg>
            Gastos
          </div>
          <div class="stat-amount" id="total-expense">$0.00</div>
        </div>
      </div>
    </div>

    <div class="quick-actions">
      <button class="action-item" id="btnAddTransaction">
        <div class="action-icon" style="background: var(--accent-gradient); border: none;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px; color: white;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <div class="action-label">Añadir</div>
      </button>
      <button class="action-item" id="btnReceive">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <div class="action-label">Recibir</div>
      </button>
      <button class="action-item">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
          </svg>
        </div>
        <div class="action-label">Tarjetas</div>
      </button>
      <button class="action-item">
        <div class="action-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
          </svg>
        </div>
        <div class="action-label">Más</div>
      </button>
    </div>

    <div class="section-header">
      <h2 class="section-title">Actividad Reciente</h2>
    </div>

    <div class="transaction-list" id="transaction-list">
      <div class="empty-state">Cargando transacciones desde Firebase...</div>
    </div>
  </main>

  <BottomNav currentPath="/" />

  <!-- Modal para Nueva Transacción -->
  <div class="modal-overlay" id="transactionModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Nueva Transacción</h3>
        <button class="close-btn" id="closeModalBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <form id="transactionForm">
        <div class="type-selector">
          <button type="button" class="type-btn active expense" data-type="expense">Gasto</button>
          <button type="button" class="type-btn income" data-type="income">Ingreso</button>
        </div>

        <div class="form-group">
          <label class="form-label">Título</label>
          <input type="text" class="form-input" id="txTitle" placeholder="Ej. Supermercado, Salario..." required>
        </div>

        <div class="form-group">
          <label class="form-label">Monto</label>
          <input type="number" class="form-input" id="txAmount" placeholder="0.00" step="0.01" min="0.01" required>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">Guardar Transacción</button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { transactionsCol, addTransaction, deleteTransactionDb, onSnapshot, query, orderBy } from '../lib/firebase.js';

  let currentType = 'expense';
  let transactions = [];

  const listEl = document.getElementById('transaction-list');
  const balanceEl = document.getElementById('total-balance');
  const incomeEl = document.getElementById('total-income');
  const expenseEl = document.getElementById('total-expense');
  
  const modal = document.getElementById('transactionModal');
  const btnAdd = document.getElementById('btnAddTransaction');
  const btnReceive = document.getElementById('btnReceive');
  const btnClose = document.getElementById('closeModalBtn');
  const form = document.getElementById('transactionForm');
  const typeBtns = document.querySelectorAll('.type-btn');
  const btnIncomeType = document.querySelector('.type-btn.income');
  const submitBtn = document.getElementById('submitBtn');

  const formatCurrency = (amount) => '$' + Math.abs(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const getFormattedDate = () => {
    const now = new Date();
    return now.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit' });
  };

  const updateUI = () => {
    const income = transactions.filter(t => t.amount > 0).reduce((acc, t) => acc + t.amount, 0);
    const expense = transactions.filter(t => t.amount < 0).reduce((acc, t) => acc + t.amount, 0);
    const balance = income + expense;

    balanceEl.textContent = formatCurrency(balance);
    incomeEl.textContent = formatCurrency(income);
    expenseEl.textContent = formatCurrency(expense);

    listEl.innerHTML = '';
    
    if (transactions.length === 0) {
      listEl.innerHTML = '<div class="empty-state">No hay transacciones aún. <br>¡Añade una para empezar!</div>';
      return;
    }

    transactions.forEach(tx => {
      const isPositive = tx.amount > 0;
      let colorCode = isPositive ? '#34d399' : '#f87171';
      let bgStyle = isPositive ? 'background-color: rgba(52, 211, 153, 0.2)' : 'background-color: rgba(248, 113, 113, 0.2)';
      let iconSvg = isPositive 
        ? '<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l6.75-6.75M12 19.5l-6.75-6.75" />' 
        : '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />';

      const div = document.createElement('div');
      div.className = 'transaction-item';
      div.innerHTML = `
        <div class="tx-left">
          <div class="tx-icon" style="${bgStyle}">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 24px; height: 24px; color: ${colorCode}">
              ${iconSvg}
            </svg>
          </div>
          <div class="tx-details">
            <div class="tx-title">${tx.title}</div>
            <div class="tx-date">${tx.date}</div>
          </div>
        </div>
        <div class="tx-amount ${isPositive ? 'positive' : ''}" style="${isPositive ? 'color: var(--positive);' : ''}">
          ${isPositive ? '+' : '-'}${formatCurrency(tx.amount)}
        </div>
        <button class="delete-btn" onclick="window.deleteTransaction('${tx.id}')" title="Eliminar">×</button>
      `;
      listEl.appendChild(div);
    });
  };

  // Escuchar cambios de Firebase en tiempo real
  const q = query(transactionsCol, orderBy("createdAt", "desc"));
  onSnapshot(q, (snapshot) => {
    transactions = [];
    snapshot.forEach((doc) => {
      transactions.push({ id: doc.id, ...doc.data() });
    });
    updateUI();
  }, (error) => {
    console.error("Error al escuchar Firebase:", error);
    if (error.code === 'permission-denied') {
      alert("Error de Permisos: Firebase está bloqueando la lectura. Por favor, ve a Firestore Database -> Reglas y pon 'allow read, write: if true;'");
    } else if (error.code === 'failed-precondition' && error.message.includes('index')) {
      alert("Falta crear un índice en Firebase. Por favor, revisa la consola de tu navegador para obtener el enlace de creación.");
    } else {
      alert("Error de Firebase: " + error.message);
    }
  });

  window.deleteTransaction = async (id) => {
    await deleteTransactionDb(id);
  };

  btnAdd.addEventListener('click', () => {
    modal.classList.add('active');
    setTimeout(() => document.getElementById('txTitle').focus(), 100);
  });

  btnReceive.addEventListener('click', () => {
    modal.classList.add('active');
    btnIncomeType.click();
    setTimeout(() => document.getElementById('txTitle').focus(), 100);
  });

  btnClose.addEventListener('click', () => {
    modal.classList.remove('active');
    form.reset();
  });

  typeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      typeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentType = btn.dataset.type;
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Guardando...';
    
    const title = document.getElementById('txTitle').value;
    const amountVal = parseFloat(document.getElementById('txAmount').value);
    
    if (!title || isNaN(amountVal)) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Guardar Transacción';
      return;
    }

    const newTx = {
      title,
      amount: currentType === 'expense' ? -amountVal : amountVal,
      date: getFormattedDate()
    };

    await addTransaction(newTx);
    
    modal.classList.remove('active');
    form.reset();
    submitBtn.disabled = false;
    submitBtn.textContent = 'Guardar Transacción';
  });

</script>
