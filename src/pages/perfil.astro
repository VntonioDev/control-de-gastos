---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Perfil | Control de Gastos">
  <header>
    <div class="user-info">
      <div>
        <div class="name">Mi Perfil</div>
      </div>
    </div>
  </header>

  <main class="main-content">
    <div style="text-align: center; margin-top: 32px;">
      <div class="avatar" style="width: 100px; height: 100px; margin: 0 auto 16px;">
        <img src="https://i.pravatar.cc/150?img=11" alt="User Avatar" />
      </div>
      <h2 style="font-size: 1.5rem; font-weight: 600;">Jose</h2>
      <p style="color: var(--text-secondary); margin-bottom: 32px;">jose@example.com</p>

      <button style="background: var(--card-bg); border: 1px solid var(--card-border); color: var(--text-primary); padding: 16px 32px; border-radius: 16px; cursor: pointer; width: 100%; margin-bottom: 16px; transition: background 0.2s ease;">
        Ajustes de la cuenta
      </button>

      <button style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--negative); color: var(--negative); padding: 16px 32px; border-radius: 16px; cursor: pointer; width: 100%; transition: background 0.2s ease;">
        Cerrar Sesión
      </button>
    </div>
  </main>

  <BottomNav currentPath="/perfil" />
</Layout>
