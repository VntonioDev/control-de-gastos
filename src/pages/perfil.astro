---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Perfil | Control de Gastos">
  <header>
    <div class="user-info">
      <div>
        <div class="name">Mi Perfil</div>
      </div>
    </div>
  </header>

  <main class="main-content">
    <div style="text-align: center; margin-top: 32px;">
      <div class="avatar" style="width: 100px; height: 100px; margin: 0 auto 16px; background: var(--accent-gradient); display: flex; align-items: center; justify-content: center;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" style="width: 50px; height: 50px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
      </div>
      <h2 id="profileName" style="font-size: 1.5rem; font-weight: 600;">Cargando...</h2>
      <p id="profileEmail" style="color: var(--text-secondary); margin-bottom: 32px;">...</p>

      <button id="settingsBtn" style="background: var(--card-bg); border: 1px solid var(--card-border); color: var(--text-primary); padding: 16px 32px; border-radius: 16px; cursor: pointer; width: 100%; margin-bottom: 16px; transition: background 0.2s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Ajustes de la cuenta
      </button>

      <button id="logoutBtn" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--negative); color: var(--negative); padding: 16px 32px; border-radius: 16px; cursor: pointer; width: 100%; transition: background 0.2s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
        </svg>
        Cerrar Sesión
      </button>
    </div>

    <!-- Sección de Suscripciones -->
    <div class="section-header" style="margin-top: 32px; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="section-title">Suscripciones Fijas</h2>
      <button id="openSubModalBtn" onclick="document.getElementById('subModal').classList.add('active')" style="background: var(--accent); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; font-size: 1.2rem; cursor: pointer;">+</button>
    </div>
    <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 24px; padding: 16px;">
      <div id="subsList">
        <div class="empty-state" style="font-size: 0.9rem;">Cargando suscripciones...</div>
      </div>
      <div style="display: flex; justify-content: space-between; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--card-border); font-weight: 600;">
        <span>Total mensual:</span>
        <span id="subsTotal" style="color: var(--negative);">$0.00</span>
      </div>
    </div>
  </main>

  <BottomNav currentPath="/perfil" />

  <!-- Modal de Ajustes -->
  <div class="modal-overlay" id="settingsModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Ajustes</h3>
        <button class="close-btn" id="closeSettingsBtn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <div class="form-group">
        <label class="form-label">Nombre a mostrar</label>
        <div style="display: flex; gap: 8px;">
          <input type="text" class="form-input" id="profileNameInput" placeholder="Tu nombre">
          <button id="updateNameBtn" style="background: var(--accent); color: white; border: none; padding: 0 16px; border-radius: 12px; font-weight: 600; cursor: pointer;">Guardar</button>
        </div>
      </div>

      <div style="margin-top: 24px;">
        <button id="exportCsvBtn" style="background: var(--card-bg); border: 1px solid var(--card-border); color: var(--text-primary); padding: 12px 24px; border-radius: 12px; cursor: pointer; width: 100%; font-weight: 600; display: flex; justify-content: center; align-items: center; gap: 8px;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Exportar Transacciones a CSV
        </button>
      </div>

      <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--card-border);">
        <h4 style="color: var(--negative); margin-bottom: 8px;">Zona de Peligro</h4>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 16px;">Eliminar todas tus transacciones de forma permanente. Esta acción no se puede deshacer.</p>
        <button id="deleteAllBtn" style="background: rgba(239, 68, 68, 0.2); border: 1px solid var(--negative); color: var(--negative); padding: 12px 24px; border-radius: 12px; cursor: pointer; width: 100%; font-weight: 600;">
          Borrar todos mis datos
        </button>
      </div>
    </div>
  </div>

  <!-- Modal Suscripción -->
  <div class="modal-overlay" id="subModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Nueva Suscripción</h3>
        <button class="close-btn" id="closeSubModalBtn" onclick="document.getElementById('subModal').classList.remove('active'); document.getElementById('subForm').reset();">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="subForm">
        <div class="form-group">
          <label class="form-label">Servicio (Ej. Netflix)</label>
          <input type="text" class="form-input" id="subName" required>
        </div>
        <div class="form-group">
          <label class="form-label">Costo mensual</label>
          <input type="number" class="form-input" id="subAmount" step="0.01" min="0" required>
        </div>
        <button type="submit" class="submit-btn" id="saveSubBtn">Añadir Suscripción</button>
      </form>
    </div>
  </div>

  <script>
    import { auth, signOut, db, subscriptionsCol, addSubscription, deleteSubscriptionDb, onSnapshot, query, where } from '../lib/firebase.js';
    import { updateProfile } from "firebase/auth";
    import { collection, getDocs, deleteDoc, doc } from "firebase/firestore";

    const profileName = document.getElementById('profileName');
    const profileEmail = document.getElementById('profileEmail');
    const logoutBtn = document.getElementById('logoutBtn');
    
    // Ajustes
    const settingsBtn = document.getElementById('settingsBtn');
    const settingsModal = document.getElementById('settingsModal');
    const closeSettingsBtn = document.getElementById('closeSettingsBtn');
    const profileNameInput = document.getElementById('profileNameInput');
    const updateNameBtn = document.getElementById('updateNameBtn');
    const deleteAllBtn = document.getElementById('deleteAllBtn');
    const exportCsvBtn = document.getElementById('exportCsvBtn');

    // Suscripciones
    const openSubModalBtn = document.getElementById('openSubModalBtn');
    const subModal = document.getElementById('subModal');
    const closeSubModalBtn = document.getElementById('closeSubModalBtn');
    const subForm = document.getElementById('subForm');
    const subsList = document.getElementById('subsList');
    const subsTotal = document.getElementById('subsTotal');
    const saveSubBtn = document.getElementById('saveSubBtn');

    let currentUser = null;
    let unsubscribeSubs = null;

    const formatCurrency = (amount) => '$' + Math.abs(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    const loadSubscriptions = (user) => {
      if (unsubscribeSubs) unsubscribeSubs();
      const q = query(subscriptionsCol, where("userId", "==", user.uid));
      
      unsubscribeSubs = onSnapshot(q, (snapshot) => {
        subsList.innerHTML = '';
        let total = 0;
        let count = 0;

        snapshot.forEach((docSnap) => {
          count++;
          const data = docSnap.data();
          total += parseFloat(data.amount);

          const div = document.createElement('div');
          div.style.display = 'flex';
          div.style.justifyContent = 'space-between';
          div.style.alignItems = 'center';
          div.style.padding = '12px 0';
          div.style.borderBottom = '1px solid var(--card-border)';
          
          div.innerHTML = `
            <div>
              <div style="font-weight: 500;">${data.name}</div>
            </div>
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="color: var(--negative);">${formatCurrency(data.amount)}/m</span>
              <button onclick="window.deleteSub('${docSnap.id}')" style="background:none; border:none; color: var(--text-secondary); cursor: pointer; font-size: 1.2rem;">×</button>
            </div>
          `;
          subsList.appendChild(div);
        });

        if (count === 0) {
          subsList.innerHTML = '<div class="empty-state" style="font-size: 0.9rem;">No tienes suscripciones añadidas.</div>';
        }

        subsTotal.textContent = formatCurrency(total);
      });
    };

    auth.onAuthStateChanged((user) => {
      if (user) {
        currentUser = user;
        const displayName = user.displayName || user.email.split('@')[0];
        profileName.textContent = displayName;
        profileEmail.textContent = user.email;
        profileNameInput.value = user.displayName || '';
        loadSubscriptions(user);
      }
    });

    logoutBtn.addEventListener('click', async () => {
      try {
        await signOut(auth);
        window.location.href = '/login';
      } catch (error) {
        console.error("Error al cerrar sesión:", error);
      }
    });

    window.deleteSub = async (id) => {
      await deleteSubscriptionDb(id);
    };

    subForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!currentUser) return;

      saveSubBtn.disabled = true;
      saveSubBtn.textContent = '...';
      
      const name = document.getElementById('subName').value;
      const amount = document.getElementById('subAmount').value;

      try {
        await addSubscription({ name, amount: parseFloat(amount), userId: currentUser.uid });
        subModal.classList.remove('active');
        subForm.reset();
      } catch (error) {
        console.error(error);
        alert("Error al guardar.");
      }
      saveSubBtn.disabled = false;
      saveSubBtn.textContent = 'Añadir Suscripción';
    });

    // Ajustes
    settingsBtn.addEventListener('click', () => settingsModal.classList.add('active'));
    closeSettingsBtn.addEventListener('click', () => settingsModal.classList.remove('active'));

    updateNameBtn.addEventListener('click', async () => {
      if (!currentUser) return;
      const newName = profileNameInput.value.trim();
      if (!newName) return;
      updateNameBtn.textContent = '...';
      try {
        await updateProfile(currentUser, { displayName: newName });
        profileName.textContent = newName;
      } catch (e) {}
      updateNameBtn.textContent = 'Guardar';
    });

    // CSV Export
    exportCsvBtn.addEventListener('click', async () => {
      if (!currentUser) return;
      exportCsvBtn.textContent = 'Generando...';
      
      try {
        const q = query(collection(db, "transactions"), where("userId", "==", currentUser.uid));
        const snapshot = await getDocs(q);
        
        let csvContent = "data:text/csv;charset=utf-8,";
        csvContent += "Fecha,Titulo,Categoria,Monto\n";

        snapshot.forEach((docSnap) => {
          const d = docSnap.data();
          const amountStr = d.amount.toString();
          csvContent += `"${d.date}","${d.title}","${d.category}","${amountStr}"\n`;
        });

        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "mis_gastos.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      } catch(e) {
        console.error(e);
        alert("Error al exportar.");
      }
      exportCsvBtn.innerHTML = 'Exportar Transacciones a CSV';
    });

    deleteAllBtn.addEventListener('click', async () => {
      if (!currentUser) return;
      const confirmDelete = confirm("¿Estás 100% seguro de que quieres borrar TODOS tus datos?");
      if (!confirmDelete) return;
      deleteAllBtn.textContent = 'Borrando...';
      try {
        const q = query(collection(db, "transactions"), where("userId", "==", currentUser.uid));
        const snapshot = await getDocs(q);
        const deletePromises = [];
        snapshot.forEach((document) => deletePromises.push(deleteDoc(doc(db, "transactions", document.id))));
        await Promise.all(deletePromises);
        alert("Todos tus datos han sido eliminados.");
        settingsModal.classList.remove('active');
      } catch (e) {
        console.error(e);
      }
      deleteAllBtn.textContent = 'Borrar todos mis datos';
    });

  </script>
</Layout>
