---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Análisis | Control de Gastos">
  <header>
    <div class="user-info" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
      <div>
        <div class="name">Análisis</div>
        <div class="greeting">Desglose de tus finanzas</div>
      </div>
      <div>
        <select id="monthFilter" style="background: var(--card-bg); color: var(--text-primary); border: 1px solid var(--card-border); padding: 4px 8px; border-radius: 8px; font-family: 'Outfit', sans-serif; font-size: 0.85rem; outline: none; cursor: pointer;">
          <option value="current">Este mes</option>
          <option value="last">Mes pasado</option>
          <option value="all">Todos</option>
        </select>
      </div>
    </div>
  </header>

  <main class="main-content">
    
    <div class="balance-card" style="margin-top: 0;">
      <div class="balance-label">Gastos por Categoría</div>
      <div style="height: 220px; width: 100%; position: relative; margin-top: 16px;">
        <canvas id="myChart"></canvas>
        <div id="chartLoading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: rgba(255,255,255,0.7); font-size: 0.9rem;">
          Cargando datos...
        </div>
      </div>
    </div>

    <div class="section-header" style="margin-top: 24px;">
      <h2 class="section-title">Detalle</h2>
    </div>

    <div class="transaction-list" id="category-list">
      <!-- Se llenará dinámicamente -->
    </div>

    <div class="section-header" style="margin-top: 32px; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="section-title">Presupuestos</h2>
      <button id="openBudgetModal" style="background: var(--accent); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; font-size: 1.2rem; cursor: pointer;">+</button>
    </div>

    <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 24px; padding: 16px; margin-bottom: 32px;">
      <div id="budgetsList">
        <div class="empty-state" style="font-size: 0.9rem;">No has definido presupuestos.</div>
      </div>
    </div>

  </main>

  <BottomNav slot="bottom-nav" currentPath="/analisis" />

  <!-- Modal Presupuesto -->
  <div class="modal-overlay" id="budgetModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Límite de Presupuesto</h3>
        <button class="close-btn" id="closeBudgetModal">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="budgetForm">
        <div class="form-group">
          <label class="form-label">Categoría</label>
          <select class="form-input" id="budgetCategory" required style="appearance: none;">
            <option value="Alimentación">Alimentación</option>
            <option value="Transporte">Transporte</option>
            <option value="Ocio">Ocio</option>
            <option value="Servicios">Servicios</option>
            <option value="Salud">Salud</option>
            <option value="Otros">Otros</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Límite mensual máximo</label>
          <input type="text" inputmode="numeric" class="form-input" id="budgetAmount" placeholder="Ej: 100.000" required>
        </div>
        <button type="submit" class="submit-btn" id="saveBudgetBtn">Guardar Presupuesto</button>
      </form>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <script>
    import { auth, onAuthStateChanged, transactionsCol, budgetsCol, subscriptionsCol, setBudget, onSnapshot, query, where, deleteDoc, doc, db } from '../lib/firebase.js';

    const chartLoading = document.getElementById('chartLoading');
    const categoryList = document.getElementById('category-list');
    const monthFilter = document.getElementById('monthFilter');
    const budgetsList = document.getElementById('budgetsList');
    const budgetModal = document.getElementById('budgetModal');
    const openBudgetModal = document.getElementById('openBudgetModal');
    const closeBudgetModal = document.getElementById('closeBudgetModal');
    const budgetForm = document.getElementById('budgetForm');
    
    let chartInstance = null;
    let allTransactions = [];
    let displayedTransactions = [];
    let allSubscriptions = [];
    let userBudgets = {}; // { category: amount }
    let budgetIds = {}; // { category: docId }
    let currentUser = null;
    let unsubscribeTx = null;
    let unsubscribeBg = null;
    let unsubscribeSubs = null;

    const formatCurrency = (amount) => Math.round(Math.abs(amount)).toLocaleString('es-CL') + ' CLP';

    const chartColors = ['#ef4444', '#f59e0b', '#3b82f6', '#8b5cf6', '#10b981', '#64748b'];

    const filterTransactions = () => {
      const filter = monthFilter.value;
      if (filter === 'all') {
        displayedTransactions = [...allTransactions];
      } else {
        const now = new Date();
        const currentMonth = now.getMonth();
        const currentYear = now.getFullYear();

        displayedTransactions = allTransactions.filter(tx => {
          if (!tx.createdAt) return true;
          const txDate = new Date(tx.createdAt);
          if (filter === 'current') return txDate.getMonth() === currentMonth && txDate.getFullYear() === currentYear;
          if (filter === 'last') {
            let lastMonth = currentMonth - 1;
            let lastYear = currentYear;
            if (lastMonth < 0) { lastMonth = 11; lastYear--; }
            return txDate.getMonth() === lastMonth && txDate.getFullYear() === lastYear;
          }
          return true;
        });
      }
      updateUI();
    };

    monthFilter.addEventListener('change', filterTransactions);

    const updateUI = () => {
      const categoryTotals = {};
      
      displayedTransactions.forEach((tx) => {
        if (tx.amount < 0) {
          const cat = tx.category || 'Otros';
          categoryTotals[cat] = (categoryTotals[cat] || 0) + Math.abs(tx.amount);
        }
      });

      // Añadir suscripciones si hay
      const subsTotal = allSubscriptions.reduce((acc, sub) => acc + parseFloat(sub.amount), 0);
      if (subsTotal > 0) {
        categoryTotals['Suscripciones Fijas'] = subsTotal;
      }

      // Actualizar Gráfico y Lista de Categorías
      chartLoading.style.display = 'none';
      categoryList.innerHTML = '';
      const labels = Object.keys(categoryTotals);
      const data = Object.values(categoryTotals);

      if (labels.length === 0) {
        chartLoading.style.display = 'block';
        chartLoading.textContent = "No hay gastos en este periodo.";
      } else {
        labels.forEach((label, i) => {
          const div = document.createElement('div');
          div.className = 'transaction-item';
          div.innerHTML = `
            <div class="tx-left">
              <div class="tx-icon" style="background-color: ${chartColors[i % chartColors.length]}33">
                <div style="width: 16px; height: 16px; border-radius: 50%; background-color: ${chartColors[i % chartColors.length]};"></div>
              </div>
              <div class="tx-details">
                <div class="tx-title">${label}</div>
              </div>
            </div>
            <div class="tx-amount negative" style="color: var(--negative);">
              -${formatCurrency(data[i])}
            </div>
          `;
          categoryList.appendChild(div);
        });
      }

      if (chartInstance) chartInstance.destroy();
      if (labels.length > 0) {
        chartInstance = new Chart(document.getElementById('myChart'), {
          type: 'doughnut',
          data: {
            labels: labels,
            datasets: [{ data: data, backgroundColor: chartColors.slice(0, labels.length), borderWidth: 0, hoverOffset: 4 }]
          },
          options: {
            responsive: true, maintainAspectRatio: false, cutout: '75%',
            plugins: { legend: { position: 'right', labels: { color: 'rgba(255, 255, 255, 0.8)', font: { family: "'Outfit', sans-serif" }, padding: 10, boxWidth: 12 } } }
          }
        });
      }

      // Actualizar Barras de Presupuesto
      renderBudgets(categoryTotals);
    };

    const renderBudgets = (categoryTotals) => {
      budgetsList.innerHTML = '';
      const budgetKeys = Object.keys(userBudgets);
      if (budgetKeys.length === 0) {
        budgetsList.innerHTML = '<div class="empty-state" style="font-size: 0.9rem;">No has definido presupuestos.</div>';
        return;
      }

      budgetKeys.forEach(cat => {
        const limit = userBudgets[cat];
        const spent = categoryTotals[cat] || 0;
        const percentage = Math.min((spent / limit) * 100, 100);
        const isCritical = percentage >= 90;
        const barColor = isCritical ? 'var(--negative)' : (percentage > 70 ? '#f59e0b' : 'var(--positive)');

        const div = document.createElement('div');
        div.style.marginBottom = '16px';
        div.innerHTML = `
          <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem;">
            <span>${cat}</span>
            <span><strong style="color: ${isCritical ? 'var(--negative)' : 'var(--text-primary)'}">${formatCurrency(spent)}</strong> / ${formatCurrency(limit)}</span>
          </div>
          <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-bottom: 8px;">
            <div style="width: ${percentage}%; height: 100%; background: ${barColor}; transition: width 0.3s ease;"></div>
          </div>
          <div style="text-align: right;">
            <button onclick="window.deleteBudget('${budgetIds[cat]}')" style="background:none; border:none; color: var(--text-secondary); cursor: pointer; font-size: 0.8rem; text-decoration: underline;">Eliminar</button>
          </div>
        `;
        budgetsList.appendChild(div);
      });
    };

    onAuthStateChanged(auth, (user) => {
      if (user) {
        currentUser = user;
        
        // Cargar Transacciones
        if (unsubscribeTx) unsubscribeTx();
        const qTx = query(transactionsCol, where("userId", "==", user.uid));
        unsubscribeTx = onSnapshot(qTx, (snapshot) => {
          allTransactions = [];
          snapshot.forEach(doc => allTransactions.push({ id: doc.id, ...doc.data() }));
          filterTransactions();
        });

        // Cargar Presupuestos
        if (unsubscribeBg) unsubscribeBg();
        const qBg = query(budgetsCol, where("userId", "==", user.uid));
        unsubscribeBg = onSnapshot(qBg, (snapshot) => {
          userBudgets = {};
          budgetIds = {};
          snapshot.forEach(docSnap => {
            const data = docSnap.data();
            userBudgets[data.category] = data.amount;
            budgetIds[data.category] = docSnap.id;
          });
          updateUI(); // Para redibujar barras con nuevos presupuestos
        });

        // Cargar Suscripciones
        if (unsubscribeSubs) unsubscribeSubs();
        const qSubs = query(subscriptionsCol, where("userId", "==", user.uid));
        unsubscribeSubs = onSnapshot(qSubs, (snapshot) => {
          allSubscriptions = [];
          snapshot.forEach(docSnap => {
            allSubscriptions.push({ id: docSnap.id, ...docSnap.data() });
          });
          updateUI(); // Para redibujar gráfico con suscripciones
        });
      }
    });

    window.deleteBudget = async (id) => {
      await deleteDoc(doc(db, "budgets", id));
    };

    openBudgetModal.addEventListener('click', () => budgetModal.classList.add('active'));
    closeBudgetModal.addEventListener('click', () => { budgetModal.classList.remove('active'); budgetForm.reset(); });

    budgetForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!currentUser) return;

      const btn = document.getElementById('saveBudgetBtn');
      btn.disabled = true;
      btn.textContent = 'Guardando...';

      const cat = document.getElementById('budgetCategory').value;
      const rawAmount = document.getElementById('budgetAmount').value;
      const amount = parseFloat(rawAmount.replace(/\./g, '').replace(/,/g, '.'));

      try {
        // Si ya hay presupuesto, borrar el viejo (simplificación en vez de upsert)
        if (budgetIds[cat]) {
          await deleteDoc(doc(db, "budgets", budgetIds[cat]));
        }
        await setBudget({ userId: currentUser.uid, category: cat, amount });
        budgetModal.classList.remove('active');
        budgetForm.reset();
      } catch (e) {
        alert("Error al guardar presupuesto");
      }
      btn.disabled = false;
      btn.textContent = 'Guardar Presupuesto';
    });

  </script>
</Layout>
