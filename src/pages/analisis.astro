---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Análisis | Control de Gastos">
  <header>
    <div class="user-info">
      <div>
        <div class="name">Análisis</div>
        <div class="greeting">Desglose de tus finanzas</div>
      </div>
    </div>
  </header>

  <main class="main-content">
    
    <div class="balance-card" style="margin-top: 0;">
      <div class="balance-label">Gastos por Categoría</div>
      <div style="height: 220px; width: 100%; position: relative; margin-top: 16px;">
        <canvas id="myChart"></canvas>
        <div id="chartLoading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: rgba(255,255,255,0.7); font-size: 0.9rem;">
          Cargando datos...
        </div>
      </div>
    </div>

    <div class="section-header" style="margin-top: 24px;">
      <h2 class="section-title">Detalle</h2>
    </div>

    <div class="transaction-list" id="category-list">
      <!-- Se llenará dinámicamente -->
    </div>

  </main>

  <BottomNav currentPath="/analisis" />

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <script>
    import { auth, transactionsCol, onSnapshot, query, where } from '../lib/firebase.js';

    const chartLoading = document.getElementById('chartLoading');
    const categoryList = document.getElementById('category-list');
    
    let chartInstance = null;

    const formatCurrency = (amount) => '$' + Math.abs(amount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    const chartColors = [
      '#ef4444', // Alimentación (rojo)
      '#f59e0b', // Transporte (naranja)
      '#3b82f6', // Ocio (azul)
      '#8b5cf6', // Servicios (morado)
      '#10b981', // Salud (verde)
      '#64748b'  // Otros (gris)
    ];

    const updateChartAndList = (categoryTotals) => {
      chartLoading.style.display = 'none';
      categoryList.innerHTML = '';

      const labels = Object.keys(categoryTotals);
      const data = Object.values(categoryTotals);

      if (labels.length === 0) {
        chartLoading.style.display = 'block';
        chartLoading.textContent = "No hay gastos aún.";
        return;
      }

      // Rellenar lista
      labels.forEach((label, i) => {
        const div = document.createElement('div');
        div.className = 'transaction-item';
        div.innerHTML = `
          <div class="tx-left">
            <div class="tx-icon" style="background-color: ${chartColors[i % chartColors.length]}33">
              <div style="width: 16px; height: 16px; border-radius: 50%; background-color: ${chartColors[i % chartColors.length]};"></div>
            </div>
            <div class="tx-details">
              <div class="tx-title">${label}</div>
            </div>
          </div>
          <div class="tx-amount negative" style="color: var(--negative);">
            -${formatCurrency(data[i])}
          </div>
        `;
        categoryList.appendChild(div);
      });

      // Actualizar gráfico
      const ctx = document.getElementById('myChart');
      if (chartInstance) {
        chartInstance.destroy();
      }

      chartInstance = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: data,
            backgroundColor: chartColors.slice(0, labels.length),
            borderWidth: 0,
            hoverOffset: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '75%',
          plugins: {
            legend: {
              position: 'right',
              labels: {
                color: 'rgba(255, 255, 255, 0.8)',
                font: { family: "'Outfit', sans-serif" },
                padding: 10,
                boxWidth: 12
              }
            }
          }
        }
      });
    };

    auth.onAuthStateChanged((user) => {
      if (user) {
        const q = query(transactionsCol, where("userId", "==", user.uid));
        onSnapshot(q, (snapshot) => {
          const categoryTotals = {};

          snapshot.forEach((doc) => {
            const data = doc.data();
            // Solo analizamos gastos (amount < 0)
            if (data.amount < 0) {
              const cat = data.category || 'Otros';
              categoryTotals[cat] = (categoryTotals[cat] || 0) + Math.abs(data.amount);
            }
          });

          updateChartAndList(categoryTotals);
        }, (error) => {
          console.error(error);
          chartLoading.textContent = "Error al cargar datos";
        });
      }
    });

  </script>
</Layout>
