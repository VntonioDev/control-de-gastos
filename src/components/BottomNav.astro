---
const { currentPath } = Astro.props;
---

<nav class="bottom-nav">
  <a href="/" class={`nav-item ${currentPath === '/' ? 'active' : ''}`}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="nav-icon">
      <path d="M11.47 3.84a.75.75 0 011.06 0l8.99 8.99a.75.75 0 01-1.06 1.06l-4.63-4.63V20.25a.75.75 0 01-.75.75h-3.75a.75.75 0 01-.75-.75V15a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75v5.25a.75.75 0 01-.75.75H4.5a.75.75 0 01-.75-.75v-10.99l-4.63 4.63a.75.75 0 01-1.06-1.06l8.99-8.99z" />
    </svg>
    <span style="font-size: 0.7rem; font-weight: 500;">Inicio</span>
  </a>
  <a href="/analisis" class={`nav-item ${currentPath === '/analisis' ? 'active' : ''}`}>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="nav-icon">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
    </svg>
    <span style="font-size: 0.7rem; font-weight: 500;">Análisis</span>
  </a>
  <a href="/perfil" class={`nav-item ${currentPath === '/perfil' ? 'active' : ''}`}>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="nav-icon">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
    </svg>
    <span style="font-size: 0.7rem; font-weight: 500;">Perfil</span>
  </a>
</nav>

<style is:global>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px;
    height: 80px;
    background: rgba(15, 17, 26, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--card-border);
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0 8px;
    z-index: 10;
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 16px;
    transition: all 0.3s ease;
  }

  .nav-item.active {
    color: var(--accent);
  }

  .nav-item:hover {
    color: var(--text-primary);
  }

  .nav-icon {
    width: 24px;
    height: 24px;
  }
</style>
